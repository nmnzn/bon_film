      </div>
      <div class="d-flex gap-4">
        <a href="#">Confidentialité</a>
        <a href="#">Conditions</a>
        <a href="#">Contact</a>
      </div>
      <p class="mb-0" style="font-size:.875rem; color:#64748b;">© 2026 Bon Film ! AI. Tous droits réservés.</p>
    </div>
  </footer>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
