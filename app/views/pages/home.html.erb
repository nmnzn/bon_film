<!DOCTYPE html>
<html lang="fr" data-bs-theme="dark">
<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <%# <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"> %>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <%# <link href="../../assets/stylesheets/landing.css" rel="stylesheet"> %>
  <title>Bon Film ! AI - Votre Assistant Cinéma Intelligent</title>
</head>

<body>
  <% content_for :navbar_actions do %>
    <%= link_to "Mes listes", lists_path, class: "btn btn-accent btn-sm" %>
  <% end %> 

<div class="d-flex flex-column min-vh-100">

  <!-- ════════════════════════════════ HERO ════════════════════════════════ -->
  <main class="flex-grow-1">
    <section class="px-3 px-md-5 py-5" style="max-width:1280px; margin:0 auto;">
      <div class="row g-5 align-items-center py-4 py-md-5">

        <!-- Left col -->
        <div class="col-lg-6 d-flex flex-column gap-4">

          <div>
            <span class="badge-era">
              <span class="material-symbols-outlined" style="font-size:14px;">auto_awesome</span>
              Nouvelle Ère Cinéma
            </span>
          </div>

          <div>
            <h1 class="fw-black lh-tight mb-3" style="font-size:clamp(2.2rem,5vw,3.75rem);">
              Le premier assistant IA qui sait
              <span class="text-primary-custom">vraiment</span>
              ce que vous voulez voir.
            </h1>
            <p class="text-muted-custom fs-5">
              Découvrez des films qui vous correspondent grâce à notre IA de pointe. Fini de scroller pendant des heures.
            </p>
          </div>

          <div class="d-flex flex-wrap gap-3">
            <%= link_to "Commencez maintenant !", lists_path, class: "btn-hero-primary" %>
            <%= link_to "Découvrir !", lists_path, class: "btn-hero-outline" %>
          </div>
        </div>

        <!-- Right col – image + overlays -->
        <div class="col-lg-6">
          <div class="position-relative" style="padding-top:1.5rem; padding-right:1rem;">

            <!-- XP badge -->
            <div class="xp-badge d-none d-md-block">
              <p class="mb-2" style="font-size:.65rem; color:#94a3b8; text-transform:uppercase; font-weight:700; letter-spacing:.1em;">Niveau Actuel</p>
              <div class="d-flex align-items-center gap-3">
                <div class="xp-icon">
                  <span class="material-symbols-outlined">military_tech</span>
                </div>
                <div>
                  <p class="mb-0 fw-bold text-white" style="font-size:.9rem; line-height:1.1;">Cinéphile Elite</p>
                  <p class="mb-0 text-primary-custom" style="font-size:.65rem;">1,250 XP • +15%</p>
                </div>
              </div>
              <div class="xp-bar-track"><div class="xp-bar-fill"></div></div>
            </div>

            <!-- Main image -->
            <div class="hero-img-wrap">
              <div class="hero-img-bg"></div>

              <!-- AI overlay -->
              <div class="ai-overlay-card">
                <div class="d-flex align-items-center gap-3">
                  <div class="ai-avatar">
                    <span class="material-symbols-outlined">smart_toy</span>
                  </div>
                  <div>
                    <p class="mb-0 text-primary-custom fw-bold" style="font-size:.65rem; text-transform:uppercase; letter-spacing:.15em;">En cours d'analyse</p>
                    <p class="mb-0 fw-medium" style="font-size:.875rem;">Suggestion : Inception (2010)</p>
                  </div>
                </div>
                <div class="avatar-stack">
                  <div class="av" style="background-image:url('https://lh3.googleusercontent.com/aida-public/AB6AXuBaFFSNOpX8qoseROOyITO4Utv5oLD8Q16HHJENdzAgcV0KqIwEeKln0nPr4BCwy_eq-r4dh0iC1Ix4kqkEl8CuyfSMJXicesniTX_u-aYv45XF48bDl06u7j9tqlXxByC5ZZMqHwlx4sLvUaEmFEk2Cec7jCL7edN1t-eRot3s5ij9HCp2CLsbEpS_kUK_XNaAW-67NSNc88P7L_U9hhW1sYpt9qQZIQesSalU_apA7j6tQg91n8_HZ1s12dCb14RGUsOO4Ht70Bc');"></div>
                  <div class="av" style="background-image:url('https://lh3.googleusercontent.com/aida-public/AB6AXuCbjXGewv4ljYmPC5DCYWG7jzwzCK9PzEwd15_Vnn0Y8ddWGN_9G_YNIcV9whEIiI1cv2KKfldSD3BgmDUKPf7VaGQFJam3yeRyOlJxUjEOHNmhXHeYmd6WRSGGe3jt6ET-4u0tUaKWSyYe1SvzbUF25fLEGKZaA7bDyKYgUfjA5RIs6O_JEdSElRBxm4aOY20kfOO4GoAe3Z5xksb-PK91SOwZIkvodz5LNS_8CjEsExnOIgey2qe0AJOqk3vSKehTuFB8UlkVhWI');"></div>
                  <div class="av-count">+12k</div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════ FEATURES ════════════════ -->
    <section class="section-features px-3 px-md-5 py-5">
      <div style="max-width:1280px; margin:0 auto;">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-4 mb-5">
          <div style="max-width:600px;">
            <h2 class="text-primary-custom fw-bold mb-3" style="font-size:.8rem; text-transform:uppercase; letter-spacing:.2em;">
              Fonctionnalités Révolutionnaires
            </h2>
            <h3 class="fw-bold lh-tight" style="font-size:clamp(1.8rem,4vw,3rem);">
              L'IA au service de votre passion
            </h3>
          </div>
          <p class="text-muted-custom" style="max-width:320px;">
            Bon Film ! AI transforme votre manière de choisir vos films avec une précision chirurgicale.
          </p>
        </div>

        <div class="row g-4">
          <div class="col-md-4">
            <div class="feature-card">
              <div class="feature-icon">
                <span class="material-symbols-outlined" style="font-size:1.75rem;">auto_fix_high</span>
              </div>
              <h4 class="fw-bold mb-3">Listes sur-mesure par IA</h4>
              <p class="text-muted-custom mb-0" style="line-height:1.7;">
                Générez instantanément une liste de films adaptée à vos envies du moment grâce à notre intelligence artificielle.
              </p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-card">
              <div class="feature-icon">
                <span class="material-symbols-outlined" style="font-size:1.75rem;">psychology</span>
              </div>
              <h4 class="fw-bold mb-3">Votre Assistant Personnel</h4>
              <p class="text-muted-custom mb-0" style="line-height:1.7;">
                Un guide interactif pour vous aider à choisir LE film parfait au sein de vos recommandations personnalisées.
              </p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-card">
              <div class="feature-icon">
                <span class="material-symbols-outlined" style="font-size:1.75rem;">bolt</span>
              </div>
              <h4 class="fw-bold mb-3">Redirection Streaming Express</h4>
              <p class="text-muted-custom mb-0" style="line-height:1.7;">
                Accédez à vos films préférés sur vos plateformes favorites (Netflix, Disney+, Canal+) en un seul clic.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ════════════════ PARTNERS ════════════════ -->
    <section class="px-3 px-md-5 py-5" style="max-width:1280px; margin:0 auto;">
      <div class="d-flex flex-wrap align-items-center justify-content-center gap-5">
        <span class="partner-logo">NETFLIX</span>
        <span class="partner-logo">Disney+</span>
        <span class="partner-logo">CANAL+</span>
        <span class="partner-logo">Prime Video</span>
        <span class="partner-logo">Apple TV+</span>
      </div>
    </section>

    <!-- ════════════════ CTA ════════════════ -->
    <section class="px-3 px-md-5 py-4">
      <div style="max-width:1280px; margin:0 auto;">
        <div class="cta-block">

          <div class="cta-deco cta-deco-tl d-none d-md-flex">
            <span class="material-symbols-outlined" style="font-size:1.75rem;">stars</span>
          </div>
          <div class="cta-deco cta-deco-br d-none d-md-flex">
            <span class="material-symbols-outlined" style="font-size:2rem;">workspace_premium</span>
          </div>

          <div class="position-relative d-flex flex-column align-items-center gap-4" style="z-index:1;">
            <h2 class="fw-black lh-tight text-dark mb-0" style="font-size:clamp(1.8rem,4vw,3rem); max-width:640px;">
              Prêt à découvrir votre prochain film coup de cœur ?
            </h2>
            <p class="mb-0" style="color:rgba(15,17,23,.75); font-size:1.1rem; max-width:480px;">
              Rejoignez plus de 50 000 cinéphiles qui ont déjà transformé leur expérience cinéma.
            </p>
            <%= link_to "Commencez maintenant !", lists_path, class: "btn-cta-dark" %>
          </div>

        </div>
      </div>
    </section>
  </main>

  <!-- ════════════════ FOOTER ════════════════ -->
  <footer class="px-3 px-md-5 py-4 mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-4" style="max-width:1280px; margin:0 auto;">
      <div class="d-flex align-items-center gap-2 text-primary-custom">
        <span class="material-symbols-outlined" style="font-size:1.4rem;">movie_filter</span>
        <span class="fw-bold" style="font-size:1.05rem;">Bon Film ! AI</span>
      </div>
      <div class="d-flex gap-4">
        <a href="#">Confidentialité</a>
        <a href="#">Conditions</a>
        <a href="#">Contact</a>
      </div>
      <p class="mb-0" style="font-size:.875rem; color:#64748b;">© 2026 Bon Film ! AI. Tous droits réservés.</p>
    </div>
  </footer>

</div>

<%# <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> %>
</body>
</html>
