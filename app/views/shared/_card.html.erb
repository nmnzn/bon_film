<div class="movie-card">
  <%= link_to movie_path(movie), class: "movie-card-poster-link" do %>
    <%= image_tag "https://image.tmdb.org/t/p/w500#{movie.poster_path}",
                  alt: movie.title,
                  class: "movie-card-poster" %>
  <% end %>

  <div class="movie-card-body">
    <%= link_to movie.title, movie_path(movie), class: "movie-card-title" %>
    <p class="movie-card-rating"><%= movie.rate_average.truncate(1) %></p>
    <p class="movie-card-overview"><%= truncate(movie.overview, length: 70) %></p>

    <% if local_assigns[:link] %>
      <%= button_to list_link_path(list, link),
          method: :delete,
          class: "btn btn-sm btn-danger-ghost card-remove-btn",
          data: { turbo_confirm: "Retirer « #{movie.title} » de la liste ?" } do %>
        <span class="material-symbols-outlined">delete</span>
        Retirer
      <% end %>
    <% end %>
  </div>
</div>
