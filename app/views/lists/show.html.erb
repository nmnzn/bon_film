  <% content_for :navbar_actions do %>
    <%= link_to "Listes", lists_path, class: "btn btn-accent btn-sm" %>
  <% end %> 

<div class="ls-page">

  <!-- Hero header : infos + chat -->
  <div class="ls-hero">
    <div class="container ls-hero-inner">

      <!-- Colonne gauche : navigation + titre + actions -->
      <div class="ls-hero-info">

        <%= link_to lists_path, class: "ls-back" do %>
          <span class="material-symbols-outlined">arrow_back</span>
          <span>Vos listes</span>
        <% end %>

        <div class="ls-hero-meta">
          <span class="ls-hero-label">
            <span class="material-symbols-outlined">movie_filter</span>
            Votre liste
          </span>
          <h1 class="ls-hero-title"><%= @list.name %></h1>
          <p class="ls-hero-count">
            <%= @list.links.count %> film<%= @list.links.count > 1 ? "s" : "" %>
          </p>
        </div>

        <div class="ls-hero-actions">
          <%= button_to (@is_favorite ? "★ Favori" : "☆ Mettre en favori"),
              toggle_favorite_list_path(@list),
              method: :post,
              class: "btn btn-sm btn-favorite" %>
          <%= link_to "Supprimer la liste",
              list_path(@list),
              data: { turbo_method: :delete, turbo_confirm: "Supprimer la liste « #{@list.name} » ?" },
              class: "btn btn-sm btn-danger-ghost" %>
        </div>

      </div>

      <!-- Colonne droite : chat -->
      <div class="ls-hero-chat">
        <%= render "shared/chat", messages: @messages, chat: @chat %>
      </div>

    </div>
  </div>

  <!-- Films -->
  <div class="container ls-films-section">
    <div class="movies-grid">
      <% @list.links.includes(:movie).each do |link| %>
        <%= render "shared/card", movie: link.movie, list: @list, link: link %>
      <% end %>
    </div>
  </div>

</div>
