<div class="row g-3 message-row">

  <div class="col-md-6">
    <% if message.role == "user" %>
      <div class="message message-user">
        <strong>Utilisateur</strong>
        <p><%= message.content %></p>
      </div>
    <% end %>
  </div>


  <div class="col-md-6">
    <% if message.role == "assistant" %>
      <div class="message message-ai">
        <strong>Assistant</strong>
        <p><%= message.content %></p>
      </div>
    <% end %>
  </div>

</div>
