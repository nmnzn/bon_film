<%= simple_form_for(list) do |f| %>
  <%= f.input :name, :label => "Nom de votre liste", :placeholder => "Film du dimanche" %>
  <%= f.input :prompt, :label => "Quel type de film souhaitez-vous ajouter dans votre liste ?", :placeholder => "Je cherche des films sympas à regarder un dimanche soir, juste pour me détendre et rire un peu." %>
  <%= f.submit class:"btn btn-accent btn-sm mb-3" %>
<% end %>
