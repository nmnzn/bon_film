            <span class="material-symbols-outlined" style="font-size:2rem;">workspace_premium</span>
          </div>

          <div class="position-relative d-flex flex-column align-items-center gap-4" style="z-index:1;">
            <h2 class="fw-black lh-tight text-dark mb-0" style="font-size:clamp(1.8rem,4vw,3rem); max-width:640px;">
              Prêt à découvrir votre prochain film coup de cœur ?
            </h2>
            <p class="mb-0" style="color:rgba(15,17,23,.75); font-size:1.1rem; max-width:480px;">
              Rejoignez plus de 50 000 cinéphiles qui ont déjà transformé leur expérience cinéma.
            </p>
            <a href="/lists" class="btn-cta-dark">Commencez maintenant !</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ════════════════ FOOTER ════════════════ -->
  <footer class="px-3 px-md-5 py-4 mt-4">
