                  <div>
                    <p class="mb-0 text-primary-custom fw-bold" style="font-size:.65rem; text-transform:uppercase; letter-spacing:.15em;">En cours d'analyse</p>
                    <p class="mb-0 fw-medium" style="font-size:.875rem;">Suggestion : Inception (2010)</p>
                  </div>
                </div>
                <div class="avatar-stack">
                  <div class="av" style="background-image:url('https://lh3.googleusercontent.com/aida-public/AB6AXuBaFFSNOpX8qoseROOyITO4Utv5oLD8Q16HHJENdzAgcV0KqIwEeKln0nPr4BCwy_eq-r4dh0iC1Ix4kqkEl8CuyfSMJXicesniTX_u-aYv45XF48bDl06u7j9tqlXxByC5ZZMqHwlx4sLvUaEmFEk2Cec7jCL7edN1t-eRot3s5ij9HCp2CLsbEpS_kUK_XNaAW-67NSNc88P7L_U9hhW1sYpt9qQZIQesSalU_apA7j6tQg91n8_HZ1s12dCb14RGUsOO4Ht70Bc');"></div>
                  <div class="av" style="background-image:url('https://lh3.googleusercontent.com/aida-public/AB6AXuCbjXGewv4ljYmPC5DCYWG7jzwzCK9PzEwd15_Vnn0Y8ddWGN_9G_YNIcV9whEIiI1cv2KKfldSD3BgmDUKPf7VaGQFJam3yeRyOlJxUjEOHNmhXHeYmd6WRSGGe3jt6ET-4u0tUaKWSyYe1SvzbUF25fLEGKZaA7bDyKYgUfjA5RIs6O_JEdSElRBxm4aOY20kfOO4GoAe3Z5xksb-PK91SOwZIkvodz5LNS_8CjEsExnOIgey2qe0AJOqk3vSKehTuFB8UlkVhWI');"></div>
                  <div class="av-count">+12k</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════ FEATURES ════════════════ -->
    <section class="section-features px-3 px-md-5 py-5">
      <div style="max-width:1280px; margin:0 auto;">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-4 mb-5">
          <div style="max-width:600px;">
            <h2 class="text-primary-custom fw-bold mb-3" style="font-size:.8rem; text-transform:uppercase; letter-spacing:.2em;">
              Fonctionnalités Révolutionnaires
            </h2>
            <h3 class="fw-bold lh-tight" style="font-size:clamp(1.8rem,4vw,3rem);">
              L'IA au service de votre passion
            </h3>
          </div>
          <p class="text-muted-custom" style="max-width:320px;">
            Bon Film ! AI transforme votre manière de choisir vos films avec une précision chirurgicale.
          </p>
        </div>

        <div class="row g-4">
          <div class="col-md-4">
