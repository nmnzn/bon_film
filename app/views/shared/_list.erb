<div class="container">
<div class="list-card-carousel mb-3">
  <div class="d-flex justify-content-between align-items-center ps-5 pe-5">
    <div>
      <%= render "shared/carousel", movies: list.movies, index: index %>
    </div>
    <h3 class="list-card-title">
      <%= list.name %>
    </h3>
    <div>
      <%= link_to "Voir", list_path(list), class: "btn btn-accent btn-sm mb-3" %>
    </div>
    <%# image_tag "logo.png", alt: "logo", class: "movie-card-poster" %>
  </div>
</div>
</div>

<%# "https://image.tmdb.org/t/p/w500#{movie.poster_path} %>
