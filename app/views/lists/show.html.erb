<div class="d-flex justify-content-between ms-5 me-5 ps-5 pt-3 pb-0 align-items-center">
  <h1><%= @list.name %></h1>

  <div class="d-flex gap-2 justify-content-center">
    <%= button_to (@is_favorite ? "★ Favori" : "☆ Mettre en favori"),
        toggle_favorite_list_path(@list),
        method: :post,
        class: "btn btn-outline-light btn-favorite" %>

    <%= link_to "Supprimer liste",
        list_path(@list),
        data: { turbo_method: :delete, turbo_confirm: "Are you sure to delete your list #{@list.name} ?" },
        class: "btn btn-danger" %>
  </div>
</div>

<div class="container">
  <div class="mt-3">
    <%= render "shared/chat", messages: @messages, chat: @chat %>
  </div>

  <div class="container mt-4">
    <% if @list.links.any? %>
      <div class="movies-grid">
        <% @list.links.includes(:movie).each do |link| %>
          <%= render "shared/card", movie: link.movie, list: @list, link: link %>
        <% end %>
      </div>
    <% else %>
      <p class="text-secondary mt-4">Aucun film dans cette liste pour le moment.</p>
    <% end %>
  </div>
</div>
